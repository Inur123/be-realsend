# ================================
# RealSend Backend Configuration
# ================================

# App
APP_PORT=3001
APP_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=realsend_user
DB_PASSWORD=realsend_secret
DB_NAME=realsend
DB_SSLMODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change-me-to-a-very-long-random-string
JWT_EXPIRE_HOURS=24

# CORS
CORS_ORIGINS=http://localhost:3000

# SMTP (development - use MailHog or Mailtrap)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=RealSend
SMTP_FROM_EMAIL=noreply@realsend.id

# Midtrans (Sandbox first)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_NOTIFICATION_URL=http://localhost:3001/api/v1/billing/midtrans/notification
MIDTRANS_FINISH_URL=http://localhost:3000/dashboard/billing?payment=success
MIDTRANS_UNFINISH_URL=http://localhost:3000/dashboard/billing?payment=unfinish
MIDTRANS_ERROR_URL=http://localhost:3000/dashboard/billing?payment=error
